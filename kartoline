import streamlit as st
from datetime import datetime

# Page configuration
st.set_page_config(page_title="Kartolinë për Mësues", page_icon="🍎")

# Custom CSS to make it look like a postcard
st.markdown("""
    <style>
    .postcard {
        background-color: #fff5f5;
        border: 5px solid white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 10px 10px 20px rgba(0,0,0,0.1);
        font-family: 'Georgia', serif;
    }
    .m-title { color: #e53e3e; font-weight: bold; }
    </style>
""", unsafe_allow_html=True)

st.title("🍎 7 Marsi: Krijo Kartolinën Tënde")
st.write("Dërgo një mesazh mirënjohjeje për mësuesit në këtë ditë speciale.")

# Sidebar Inputs
with st.sidebar:
    st.header("Detajet e Kartolinës")
    teacher_name = st.text_input("Emri i Mësuesit/es", "Znj. Ana")
    student_name = st.text_input("Emri juaj", "Nxënësi juaj")
    message = st.text_area("Mesazhi", "Faleminderit për gjithçka që keni bërë për ne!")
    bg_color = st.color_picker("Zgjidh ngjyrën e sfondit", "#fff5f5")

# The Live Preview
st.subheader("Preview i Kartolinës")
st.markdown(f"""
    <div class="postcard" style="background-color: {bg_color};">
        <h4 style="text-align: right; color: #888;">{datetime.now().strftime('%d Mars, 2026')}</h4>
        <h2 class="m-title">E dashur {teacher_name},</h2>
        <p style="font-size: 20px; line-height: 1.6; font-style: italic;">
            "{message}"
        </p>
        <br>
        <p style="text-align: right; font-weight: bold;">Me shumë respekt,<br>{student_name}</p>
    </div>
""", unsafe_allow_html=True)

# Download Button (Simulated)
if st.button("Gati për dërgim!"):
    st.balloons()
    st.success("Kartolina juaj është gati! Mund të bëni një 'Screenshot' për t'ia dërguar mësuesit.")
