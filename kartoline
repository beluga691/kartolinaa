<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kartolinë për mësues | Faleminderit!</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <style>
        .font-handwriting { font-family: 'Dancing Script', cursive; }
        .card-gradient { background: linear-gradient(135deg, #fff5f5 0%, #fed7d7 100%); }
    </style>
</head>
<body class="bg-gray-50 font-sans text-gray-900">

    <header class="py-10 text-center">
        <h1 class="text-4xl font-bold text-red-600 mb-2">7 Marsi: Kartolinë për mësues</h1>
        <p class="text-gray-600">Krijo një mesazh mirënjohjeje për mësuesin tuaj të dashur.</p>
    </header>

    <main class="max-w-4xl mx-auto px-4 grid md:grid-cols-2 gap-8 mb-20">
        
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h2 class="text-xl font-semibold mb-4 text-gray-700">Shkruani Detajet</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Emri i Mësuesit/es</label>
                    <input type="text" id="teacherName" placeholder="Psh: Znj. Ana" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-red-400 outline-none" oninput="updateCard()">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Mesazhi Juaj</label>
                    <textarea id="message" rows="4" placeholder="Shkruani diçka nga zemra..." class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-red-400 outline-none" oninput="updateCard()"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Nga Kush?</label>
                    <input type="text" id="yourName" placeholder="Emri juaj" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-red-400 outline-none" oninput="updateCard()">
                </div>
            </div>
            <button onclick="window.print()" class="mt-6 w-full bg-red-600 text-white py-3 rounded-xl font-bold hover:bg-red-700 transition">
                Shkarko / Printo si PDF
            </button>
        </div>

        <div id="capture" class="card-gradient p-8 rounded-2xl shadow-xl border-4 border-white flex flex-col min-h-[400px]">
            <div class="flex-1">
                <p class="text-sm uppercase tracking-widest text-red-500 font-bold mb-4">Gëzuar 7 Marsin!</p>
                <h3 class="text-2xl font-bold text-gray-800 mb-6">I dashur, <span id="previewTeacher">Mësues</span></h3>
                <p id="previewMessage" class="text-xl font-handwriting text-gray-700 leading-relaxed italic">
                    Faleminderit për durimin, dijen dhe frymëzimin që na jepni çdo ditë. Ju jeni një udhërrëfyes i vërtetë!
                </p>
            </div>
            <div class="mt-10 border-t border-red-200 pt-4 text-right">
                <p class="text-sm text-gray-500">Me shumë respekt,</p>
                <p id="previewFrom" class="text-lg font-bold text-gray-800">Nxënësi juaj</p>
            </div>
        </div>

    </main>

    <script>
        function updateCard() {
            const tName = document.getElementById('teacherName').value;
            const msg = document.getElementById('message').value;
            const uName = document.getElementById('yourName').value;

            if(tName) document.getElementById('previewTeacher').innerText = tName;
            if(msg) document.getElementById('previewMessage').innerText = msg;
            if(uName) document.getElementById('previewFrom').innerText = uName;
        }
    </script>
</body>
</html>
